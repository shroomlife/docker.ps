{
  "name": "docker.ps",
  "version": "0.6.5",
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "db:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "dev": "nuxt dev",
    "docker:build": "docker build -t shroomlife/docker.ps:latest .",
    "docker:down": "docker compose down",
    "docker:publish": "bun run docker:build && bun run docker:push",
    "docker:push": "docker push shroomlife/docker.ps:latest",
    "docker:up": "docker compose up -d",
    "generate": "nuxt generate",
    "postinstall": "nuxt prepare",
    "lint": "eslint . --ext .ts,.vue",
    "lint:fix": "eslint . --ext .ts,.vue --fix",
    "preview": "nuxt preview",
    "test": "bun test",
    "typecheck": "nuxt typecheck"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.4.2",
    "@prisma/client": "7.4.2",
    "axios": "1.13.6",
    "dockerode": "4.0.9",
    "dotenv": "17.3.1",
    "jsonwebtoken": "9.0.3",
    "moment": "2.30.1",
    "pg": "8.20.0",
    "strip-ansi": "7.2.0",
    "valibot": "1.2.0",
    "vue-virtual-scroller": "^2.0.0-beta.8"
  },
  "devDependencies": {
    "@iconify-json/lucide": "1.2.95",
    "@iconify-json/tabler": "1.2.29",
    "@nuxt/eslint": "1.15.2",
    "@nuxt/ui": "4.5.1",
    "@pinia/nuxt": "0.11.3",
    "@types/dockerode": "4.0.1",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "25.3.5",
    "@types/pg": "8.18.0",
    "eslint": "10.0.2",
    "nuxt": "4.3.1",
    "pinia": "3.0.4",
    "prisma": "7.4.2",
    "sass": "1.97.3",
    "typescript": "5.9.3",
    "vue": "3.5.29",
    "vue-tsc": "3.2.5"
  },
  "packageManager": "bun@1.3.10"
}
